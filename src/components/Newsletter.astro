---
---
<section class="bg-dantas-blue py-20 text-white">
  <div class="container-page grid gap-8 md:grid-cols-[1fr_.9fr] md:items-center">
    <div>
      <span class="eyebrow border-white/20 bg-white/10 text-white">Clube Casa Dantas</span>
      <h2 class="mt-5 text-4xl font-black tracking-tight sm:text-5xl">Receba novidades, promoções e tendências.</h2>
      <p class="mt-4 max-w-2xl text-blue-100">Cadastre-se para ser avisado sobre lançamentos, campanhas sazonais e ofertas especiais.</p>
    </div>
    <form class="rounded-[2rem] bg-white p-4 shadow-soft" name="newsletter" method="post">
      <label class="sr-only" for="email-newsletter">E-mail</label>
      <div class="flex flex-col gap-3 sm:flex-row">
        <input id="email-newsletter" name="email" type="email" required placeholder="seuemail@exemplo.com" class="min-h-14 flex-1 rounded-full border border-slate-200 px-5 font-semibold text-slate-900 outline-none focus:border-dantas-blue" />
        <button class="btn-primary" type="submit">Cadastrar</button>
      </div>
      <p class="mt-3 px-2 text-xs text-slate-500">Ao cadastrar, você concorda em receber comunicações da Casa Dantas.</p>
    </form>
  </div>
</section>
