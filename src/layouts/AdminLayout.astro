---
import { verifyToken } from '../utils/auth';

const token = Astro.cookies.get('admin_token')?.value;

if (!token) {
  return Astro.redirect('/admin/login');
}

const payload = await verifyToken(token);
if (!payload) {
  return Astro.redirect('/admin/login');
}
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <title>Painel - Casa Dantas</title>
</head>
<body class="bg-slate-100 flex min-h-screen">
  
  <aside class="w-64 bg-slate-900 text-white flex flex-col">
    <div class="p-6">
      <h2 class="text-2xl font-bold">Casa Dantas</h2>
      <p class="text-slate-400 text-sm">Painel Administrativo</p>
    </div>
    
    <nav class="flex-1 px-4 space-y-2">
      <a href="/admin" class="block py-2 px-4 rounded hover:bg-slate-800 transition">Dashboard</a>
      <a href="/admin/produtos" class="block py-2 px-4 rounded hover:bg-slate-800 transition">Produtos</a>
    </nav>
    
    <div class="p-4 border-t border-slate-800">
      <form action="/api/auth/logout" method="POST">
        <button type="submit" class="w-full text-left py-2 px-4 text-red-400 hover:bg-slate-800 rounded transition">Sair</button>
      </form>
    </div>
  </aside>

  <main class="flex-1 flex flex-col">
    <header class="bg-white shadow-sm py-4 px-8 flex justify-between items-center">
      <h1 class="text-xl font-semibold text-slate-800">
        <slot name="header">Bem-vindo(a)</slot>
      </h1>
      <a href="/" target="_blank" class="text-sm text-blue-600 hover:underline">Ver Site ↗</a>
    </header>
    
    <div class="p-8 flex-1 overflow-auto">
      <slot />
    </div>
  </main>

</body>
</html>
