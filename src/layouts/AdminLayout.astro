---
import '../styles/global.css';
import { getSession } from '../utils/auth';

const session = await getSession(Astro.cookies);
const currentPath = Astro.url.pathname;

if (!session) {
  return Astro.redirect('/admin/login');
}

const navItems = [
  { href: '/admin', label: 'Dashboard', icon: '▦' },
  { href: '/admin/produtos', label: 'Produtos', icon: '◈' },
  ...(session.role === 'administrador' ? [{ href: '/admin/usuarios', label: 'Usuários', icon: '◎' }] : []),
];
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Painel Administrativo | Casa Dantas</title>
</head>
<body class="min-h-screen bg-slate-100 text-slate-900 antialiased">
  <div class="min-h-screen lg:grid lg:grid-cols-[18rem_1fr]">
    <aside class="relative overflow-hidden bg-dantas-navy text-white lg:min-h-screen">
      <div class="absolute inset-0 opacity-20" style="background: radial-gradient(circle at 20% 20%, #D71920 0, transparent 28%), radial-gradient(circle at 80% 10%, #0B3A8D 0, transparent 35%);"></div>
      <div class="relative flex h-full flex-col">
        <div class="border-b border-white/10 p-6">
          <a href="/admin" class="flex items-center gap-3">
            <div class="grid h-12 w-12 place-items-center rounded-2xl bg-white text-xl font-black text-dantas-blue shadow-lg">CD</div>
            <div>
              <p class="text-xl font-black leading-none">Casa Dantas</p>
              <p class="mt-1 text-xs font-bold uppercase tracking-[0.22em] text-blue-100">Painel</p>
            </div>
          </a>
        </div>

        <nav class="relative flex-1 space-y-2 p-4">
          {navItems.map((item) => {
            const active = currentPath === item.href || (item.href !== '/admin' && currentPath.startsWith(item.href));
            return (
              <a
                href={item.href}
                class:list={[
                  'flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-black transition',
                  active ? 'bg-white text-dantas-blue shadow-lg' : 'text-blue-50 hover:bg-white/10 hover:text-white',
                ]}
              >
                <span class="grid h-8 w-8 place-items-center rounded-xl bg-current/10 text-base">{item.icon}</span>
                {item.label}
              </a>
            );
          })}
        </nav>

        <div class="relative border-t border-white/10 p-4">
          <div class="rounded-3xl bg-white/10 p-4 backdrop-blur">
            <p class="truncate text-sm font-black">{session.name || session.email}</p>
            <p class="mt-1 text-xs text-blue-100">{session.role === 'administrador' ? 'Administrador full' : 'Editor de catálogo'}</p>
          </div>
          <form action="/api/auth/logout" method="POST" class="mt-3">
            <button type="submit" class="w-full rounded-2xl border border-white/10 px-4 py-3 text-left text-sm font-black text-red-100 transition hover:bg-red-500 hover:text-white">Sair</button>
          </form>
        </div>
      </div>
    </aside>

    <main class="min-w-0">
      <header class="sticky top-0 z-10 border-b border-slate-200 bg-white/90 px-5 py-4 shadow-sm backdrop-blur lg:px-8">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="text-xs font-black uppercase tracking-[0.2em] text-dantas-red">Administração</p>
            <h1 class="mt-1 text-2xl font-black tracking-tight text-dantas-navy">
              <slot name="header">Bem-vindo(a)</slot>
            </h1>
          </div>
          <a href="/" target="_blank" class="inline-flex w-fit items-center justify-center rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-black text-dantas-blue shadow-sm transition hover:border-dantas-blue hover:bg-blue-50">Ver site ↗</a>
        </div>
      </header>

      <section class="p-5 lg:p-8">
        <slot />
      </section>
    </main>
  </div>
</body>
</html>
