---
import '../styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import WhatsAppButton from '@/components/WhatsAppButton.astro';
import { site } from '@/data/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
}

const {
  title = `${site.shortName} | ${site.slogan}`,
  description = site.description,
  image = '/og-casa-dantas.png',
  canonical = Astro.url.pathname,
} = Astro.props;
const canonicalUrl = new URL(canonical, site.domain).toString();
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0B3A8D" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL(image, site.domain).toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'ShoeStore',
      name: site.name,
      url: site.domain,
      slogan: site.slogan,
      foundingDate: '1973-05',
      telephone: site.phone,
      email: site.email,
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Rua Francisco Enéas de Lima, 1891 - Centro',
        addressLocality: 'Quixadá',
        addressRegion: 'CE',
        postalCode: '63900-231',
        addressCountry: 'BR'
      },
      sameAs: [site.instagram, site.facebook]
    })} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <WhatsAppButton />
  </body>
</html>
