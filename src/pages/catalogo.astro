---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductCatalog from '@/components/ProductCatalog';
import { getCatalogProducts } from '@/utils/catalog';

const mappedProducts = await getCatalogProducts();
---
<BaseLayout title="Vitrine | Casa Dantas Quixadá" description="Vitrine online Casa Dantas com calçados femininos, masculinos, infantis, bolsas, malas e acessórios.">
  <section class="bg-brand-radial py-20">
    <div class="container-page">
      <span class="eyebrow">Vitrine Casa Dantas</span>
      <h1 class="mt-5 max-w-4xl text-5xl font-black tracking-tight text-dantas-navy sm:text-6xl">Escolha, adicione à lista e consulte-nos pelo WhatsApp.</h1>
      <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-700">Seus Pés Sempre Na Moda. Navegue pelos nossos produtos, monte sua lista e envie direto para nossas atendentes.</p>
    </div>
  </section>
  <section class="py-14">
    <div class="container-page">
      <ProductCatalog client:load products={mappedProducts} />
    </div>
  </section>
</BaseLayout>
