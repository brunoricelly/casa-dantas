---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSession } from '../../utils/auth';

if (await getSession(Astro.cookies)) {
  return Astro.redirect('/admin');
}
---

<BaseLayout title="Login Admin - Casa Dantas" description="Área administrativa segura da Casa Dantas">
  <div class="min-h-screen flex items-center justify-center bg-slate-50 py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8 bg-white p-8 rounded-[2rem] shadow-lg border border-slate-100">
      <div class="text-center">
        <div class="mx-auto grid h-16 w-16 place-items-center rounded-2xl bg-dantas-blue text-2xl font-black text-white">CD</div>
        <h2 class="mt-6 text-3xl font-extrabold text-slate-900">Painel Casa Dantas</h2>
        <p class="mt-2 text-sm text-slate-600">Entre com Google OAuth 2.0 usando um e-mail autorizado.</p>
      </div>

      <a href="/api/auth/google" class="flex w-full items-center justify-center gap-3 rounded-full border border-slate-200 bg-white px-5 py-3 text-sm font-black text-slate-700 shadow-sm transition hover:bg-slate-50">
        <span class="grid h-6 w-6 place-items-center rounded-full bg-blue-600 text-white text-xs">G</span>
        Entrar com Google
      </a>

      <div class="rounded-2xl bg-blue-50 p-4 text-sm text-blue-900">
        <strong>Segurança:</strong> apenas e-mails previamente autorizados acessam o painel.
      </div>
    </div>
  </div>
</BaseLayout>
