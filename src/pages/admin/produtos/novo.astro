---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout>
  <span slot="header">Novo Produto</span>
  
  <div class="max-w-2xl bg-white p-8 rounded-xl shadow-sm border border-slate-100">
    <form id="produtoForm" class="space-y-6">
      
      <div>
        <label for="codigo" class="block text-sm font-medium text-slate-700">Código do Produto (Referência)</label>
        <input type="text" name="codigo" id="codigo" required class="mt-1 block w-full border border-slate-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
      </div>

      <div>
        <label for="nome" class="block text-sm font-medium text-slate-700">Nome</label>
        <input type="text" name="nome" id="nome" required class="mt-1 block w-full border border-slate-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
      </div>

      <div>
        <label for="especificacoes" class="block text-sm font-medium text-slate-700">Especificações (Material, Cor, Tamanhos)</label>
        <textarea name="especificacoes" id="especificacoes" rows="4" required class="mt-1 block w-full border border-slate-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm"></textarea>
      </div>

      <div>
        <label for="imagem" class="block text-sm font-medium text-slate-700">Imagem</label>
        <input type="file" name="imagem" id="imagem" accept="image/*" class="mt-1 block w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100">
      </div>

      <div id="error-msg" class="text-red-500 text-sm hidden">Erro ao salvar produto.</div>

      <div class="pt-4 flex justify-end space-x-3">
        <a href="/admin/produtos" class="bg-white border border-slate-300 rounded-md shadow-sm py-2 px-4 inline-flex justify-center text-sm font-medium text-slate-700 hover:bg-slate-50 focus:outline-none">
          Cancelar
        </a>
        <button type="submit" id="submitBtn" class="bg-blue-600 border border-transparent rounded-md shadow-sm py-2 px-4 inline-flex justify-center text-sm font-medium text-white hover:bg-blue-700 focus:outline-none">
          Salvar
        </button>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  const form = document.getElementById('produtoForm');
  const btn = document.getElementById('submitBtn');
  const errorMsg = document.getElementById('error-msg');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form as HTMLFormElement);
    
    btn!.textContent = 'Salvando...';
    (btn as HTMLButtonElement).disabled = true;

    try {
      const res = await fetch('/api/produtos', {
        method: 'POST',
        body: formData, // Envia multipart/form-data
      });

      if (res.ok) {
        window.location.href = '/admin/produtos';
      } else {
        errorMsg?.classList.remove('hidden');
      }
    } catch (err) {
      errorMsg?.classList.remove('hidden');
    } finally {
      btn!.textContent = 'Salvar';
      (btn as HTMLButtonElement).disabled = false;
    }
  });
</script>
