---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { categories } from '../../../data/categories';
---

<AdminLayout>
  <span slot="header">Novo Produto</span>
  
  <div class="max-w-3xl rounded-2xl border border-slate-100 bg-white p-8 shadow-sm">
    <form id="produtoForm" class="space-y-6">
      <div class="grid gap-6 sm:grid-cols-2">
        <div>
          <label for="codigo" class="block text-sm font-bold text-slate-700">Código / Referência *</label>
          <input type="text" name="codigo" id="codigo" required class="mt-1 block w-full rounded-xl border border-slate-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-blue-500 sm:text-sm" />
        </div>
        <div>
          <label for="nome" class="block text-sm font-bold text-slate-700">Nome *</label>
          <input type="text" name="nome" id="nome" required class="mt-1 block w-full rounded-xl border border-slate-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-blue-500 sm:text-sm" />
        </div>
      </div>

      <div class="grid gap-6 sm:grid-cols-2">
        <div>
          <label for="marca" class="block text-sm font-bold text-slate-700">Marca</label>
          <input type="text" name="marca" id="marca" placeholder="Ex.: Vizzano, Usaflex, Chenson" class="mt-1 block w-full rounded-xl border border-slate-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-blue-500 sm:text-sm" />
        </div>
        <div>
          <label for="categoria" class="block text-sm font-bold text-slate-700">Categoria</label>
          <select name="categoria" id="categoria" class="mt-1 block w-full rounded-xl border border-slate-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-blue-500 sm:text-sm">
            <option value="">Selecione</option>
            {categories.map((cat) => <option value={cat.slug}>{cat.name}</option>)}
          </select>
        </div>
      </div>

      <div>
        <label for="especificacoes" class="block text-sm font-bold text-slate-700">Especificações *</label>
        <textarea name="especificacoes" id="especificacoes" rows="5" required placeholder="Material, cor, tamanhos disponíveis, diferenciais..." class="mt-1 block w-full rounded-xl border border-slate-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-blue-500 sm:text-sm"></textarea>
      </div>

      <div>
        <label for="imagem" class="block text-sm font-bold text-slate-700">Imagem</label>
        <input type="file" name="imagem" id="imagem" accept="image/*" class="mt-1 block w-full text-sm text-slate-500 file:mr-4 file:rounded-full file:border-0 file:bg-blue-50 file:px-4 file:py-2 file:text-sm file:font-semibold file:text-blue-700 hover:file:bg-blue-100" />
      </div>

      <div id="error-msg" class="hidden rounded-xl bg-red-50 p-3 text-sm text-red-700">Erro ao salvar produto.</div>

      <div class="flex justify-end gap-3 pt-4">
        <a href="/admin/produtos" class="inline-flex rounded-full border border-slate-300 bg-white px-5 py-3 text-sm font-bold text-slate-700 hover:bg-slate-50">Cancelar</a>
        <button type="submit" id="submitBtn" class="inline-flex rounded-full border border-transparent bg-blue-600 px-5 py-3 text-sm font-black text-white hover:bg-blue-700">Salvar Produto</button>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  const form = document.getElementById('produtoForm') as HTMLFormElement | null;
  const btn = document.getElementById('submitBtn') as HTMLButtonElement | null;
  const errorMsg = document.getElementById('error-msg');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!btn) return;
    const formData = new FormData(form);
    btn.textContent = 'Salvando...';
    btn.disabled = true;
    errorMsg?.classList.add('hidden');

    try {
      const res = await fetch('/api/produtos', { method: 'POST', body: formData });
      if (res.ok) window.location.href = '/admin/produtos';
      else {
        const data = await res.json().catch(() => ({}));
        if (errorMsg) errorMsg.textContent = data.error || 'Erro ao salvar produto.';
        errorMsg?.classList.remove('hidden');
      }
    } catch (_) {
      errorMsg?.classList.remove('hidden');
    } finally {
      btn.textContent = 'Salvar Produto';
      btn.disabled = false;
    }
  });
</script>
