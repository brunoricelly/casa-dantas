---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db';
import { products } from '../../db/schema';
import { desc } from 'drizzle-orm';

const listaProdutos = await db.select().from(products).orderBy(desc(products.created_at));
---

<AdminLayout>
  <span slot="header">Produtos</span>

  <div class="space-y-6">
    <section class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-soft sm:p-8">
      <div class="flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="text-xs font-black uppercase tracking-[0.2em] text-dantas-red">
            Catálogo
          </p>

          <h2 class="mt-2 text-2xl font-black tracking-tight text-dantas-navy">
            Produtos da Vitrine
          </h2>

          <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-600">
            Produtos sem preço, salvos no PostgreSQL e exibidos automaticamente no catálogo público.
          </p>
        </div>

        <a
          href="/admin/produtos/novo"
          class="inline-flex items-center justify-center rounded-full bg-dantas-red px-5 py-3 text-sm font-black text-white shadow-glow transition hover:-translate-y-0.5 hover:bg-red-700"
        >
          + Novo Produto
        </a>
      </div>

      <div class="mt-6 grid gap-4 sm:grid-cols-3">
        <div class="rounded-3xl bg-blue-50 p-5">
          <p class="text-sm font-bold text-slate-500">
            Total cadastrado
          </p>

          <p class="mt-2 text-3xl font-black text-dantas-blue">
            {listaProdutos.length}
          </p>
        </div>

        <div class="rounded-3xl bg-red-50 p-5">
          <p class="text-sm font-bold text-slate-500">
            Com imagem
          </p>

          <p class="mt-2 text-3xl font-black text-dantas-red">
            {listaProdutos.filter((p) => Boolean(p.imagem_url)).length}
          </p>
        </div>

        <div class="rounded-3xl bg-slate-50 p-5">
          <p class="text-sm font-bold text-slate-500">
            Último cadastro
          </p>

          <p class="mt-2 text-sm font-black text-dantas-navy">
            {listaProdutos[0]?.nome || 'Nenhum produto'}
          </p>
        </div>
      </div>
    </section>

    <section class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-soft">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200">
          <thead class="bg-slate-50">
            <tr>
              <th class="px-5 py-4 text-left text-xs font-black uppercase tracking-wider text-slate-500">
                Imagem
              </th>

              <th class="px-5 py-4 text-left text-xs font-black uppercase tracking-wider text-slate-500">
                Código
              </th>

              <th class="px-5 py-4 text-left text-xs font-black uppercase tracking-wider text-slate-500">
                Nome
              </th>

              <th class="px-5 py-4 text-left text-xs font-black uppercase tracking-wider text-slate-500">
                Marca
              </th>

              <th class="px-5 py-4 text-left text-xs font-black uppercase tracking-wider text-slate-500">
                Categoria
              </th>

              <th class="px-5 py-4 text-left text-xs font-black uppercase tracking-wider text-slate-500">
                Status
              </th>

              <th class="px-5 py-4 text-right text-xs font-black uppercase tracking-wider text-slate-500">
                Ações
              </th>
            </tr>
          </thead>

          <tbody class="divide-y divide-slate-100 bg-white">
            {listaProdutos.map((p: any) => (
              <tr class="transition hover:bg-blue-50/40">
                <td class="whitespace-nowrap px-5 py-4">
                  {p.imagem_url ? (
                    <img
                      src={p.imagem_url}
                      alt={p.nome}
                      class="h-16 w-16 rounded-2xl border border-slate-100 object-cover shadow-sm"
                      loading="lazy"
                    />
                  ) : (
                    <div class="grid h-16 w-16 place-items-center rounded-2xl bg-slate-100 text-center text-[10px] font-black uppercase text-slate-400">
                      Sem img
                    </div>
                  )}
                </td>

                <td class="whitespace-nowrap px-5 py-4 font-black text-slate-900">
                  {p.codigo}
                </td>

                <td class="min-w-56 px-5 py-4">
                  <p class="font-bold text-slate-800">
                    {p.nome}
                  </p>

                  <p class="mt-1 line-clamp-1 text-xs text-slate-500">
                    {p.especificacoes}
                  </p>
                </td>

                <td class="whitespace-nowrap px-5 py-4 text-sm font-semibold text-slate-600">
                  {p.marca || '-'}
                </td>

                <td class="whitespace-nowrap px-5 py-4 text-sm font-semibold text-slate-600">
                  {p.categoria || '-'}
                </td>

                <td class="whitespace-nowrap px-5 py-4">
                  {p.visible !== false ? (
                    <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-black text-emerald-700">
                      Visível
                    </span>
                  ) : (
                    <span class="rounded-full bg-slate-200 px-3 py-1 text-xs font-black text-slate-600">
                      Oculto
                    </span>
                  )}
                </td>

                <td class="whitespace-nowrap px-5 py-4 text-right text-sm font-black">
                  <a
                    href={`/admin/produtos/${p.id}`}
                    class="rounded-full bg-blue-50 px-3 py-2 text-dantas-blue transition hover:bg-blue-100"
                  >
                    Editar
                  </a>

                  <button
                    data-id={p.id}
                    class="delete-product ml-2 rounded-full bg-red-50 px-3 py-2 text-dantas-red transition hover:bg-red-100"
                  >
                    Excluir
                  </button>
                </td>
              </tr>
            ))}

            {listaProdutos.length === 0 && (
              <tr>
                <td colspan="7" class="px-6 py-14 text-center">
                  <p class="text-lg font-black text-dantas-navy">
                    Nenhum produto cadastrado ainda.
                  </p>

                  <p class="mt-2 text-sm text-slate-500">
                    Clique em “Novo Produto” para publicar o primeiro item no catálogo.
                  </p>
                </td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </section>
  </div>
</AdminLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('.delete-product').forEach((button) => {
    button.addEventListener('click', async () => {
      const id = button.dataset.id;

      if (!id || !confirm('Tem certeza que deseja excluir este produto?')) return;

      const res = await fetch(`/api/produtos/${id}`, {
        method: 'DELETE',
        headers: { Accept: 'application/json' },
        credentials: 'same-origin',
      });

      if (res.ok) {
        window.location.reload();
      } else {
        const data = await res.json().catch(() => ({}));
        alert(data.error || 'Erro ao excluir produto.');
      }
    });
  });
</script>
