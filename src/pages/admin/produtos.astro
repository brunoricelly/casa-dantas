---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db';
import { products } from '../../db/schema';
import { desc } from 'drizzle-orm';

const listaProdutos = await db.select().from(products).orderBy(desc(products.created_at));
---

<AdminLayout>
  <span slot="header">Produtos</span>
  
  <div class="mb-6 flex justify-between items-center">
    <h2 class="text-xl font-medium text-slate-800">Catálogo</h2>
    <a href="/admin/produtos/novo" class="bg-blue-600 text-white px-4 py-2 rounded shadow hover:bg-blue-700 transition">
      + Novo Produto
    </a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
    <table class="min-w-full divide-y divide-slate-200">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Imagem</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Código</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Nome</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-slate-500 uppercase tracking-wider">Ações</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-slate-200">
        {listaProdutos.map((p) => (
          <tr>
            <td class="px-6 py-4 whitespace-nowrap">
              {p.imagem_url ? (
                <img src={p.imagem_url} alt={p.nome} class="h-12 w-12 object-cover rounded" />
              ) : (
                <div class="h-12 w-12 bg-slate-200 rounded flex items-center justify-center text-slate-400 text-xs">Sem img</div>
              )}
            </td>
            <td class="px-6 py-4 whitespace-nowrap font-medium text-slate-900">{p.codigo}</td>
            <td class="px-6 py-4 whitespace-nowrap text-slate-700">{p.nome}</td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
              <button onclick={`deletarProduto(${p.id})`} class="text-red-600 hover:text-red-900 ml-4">Excluir</button>
            </td>
          </tr>
        ))}
        {listaProdutos.length === 0 && (
          <tr>
            <td colspan="4" class="px-6 py-8 text-center text-slate-500">Nenhum produto cadastrado.</td>
          </tr>
        )}
      </tbody>
    </table>
  </div>
</AdminLayout>

<script>
  async function deletarProduto(id: number) {
    if (confirm('Tem certeza que deseja excluir?')) {
      const res = await fetch(`/api/produtos/${id}`, { method: 'DELETE' });
      if (res.ok) window.location.reload();
      else alert('Erro ao excluir');
    }
  }
  // Expose to window for inline onclick
  (window as any).deletarProduto = deletarProduto;
</script>
