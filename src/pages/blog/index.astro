---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Blog | Casa Dantas" description="Dicas de moda, tendências, calçados e acessórios da Casa Dantas.">
  <section class="bg-brand-radial py-24">
    <div class="container-page">
      <span class="eyebrow">Blog & tendências</span>
      <h1 class="mt-5 text-5xl font-black tracking-tight text-dantas-navy">Moda, conforto e novidades para seus pés.</h1>
    </div>
  </section>
  <section class="py-16">
    <div class="container-page grid gap-6 md:grid-cols-3">
      <a class="card p-7 transition hover:-translate-y-1" href="/blog/tendencias-calcados-2026">
        <p class="text-sm font-black uppercase tracking-[0.2em] text-dantas-red">Tendências</p>
        <h2 class="mt-4 text-2xl font-black text-dantas-navy">Como escolher calçados versáteis para sua rotina</h2>
        <p class="mt-3 leading-7 text-slate-600">Dicas para combinar conforto, durabilidade e estilo.</p>
      </a>
    </div>
  </section>
</BaseLayout>
